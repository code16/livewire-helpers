{
    "name": "code16/livewire-helpers",
    "description": "A bunch of helpers for our livewire projects",
    "keywords": [
        "code16",
        "laravel",
        "livewire-helpers"
    ],
    "homepage": "https://github.com/code16/livewire-helpers",
    "license": "MIT",
    "authors": [
        {
            "name": "code16",
            "email": "antoine@code16.fr",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "code16/pint-config": "^1.2",
        "illuminate/contracts": "^12.0||^13.0",
        "livewire/livewire": "^4.2",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^11.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Code16\\Livewire\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Code16\\Livewire\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@composer run prepare",
            "@php vendor/bin/testbench pint-config:install"
        ],
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Code16\\Livewire\\LivewireServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
